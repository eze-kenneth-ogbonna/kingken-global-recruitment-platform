# ── Whitelist: only project folders ──
/*
!/.gitignore
!/.github
!/.github/**
!/.vscode
!/.vscode/**
!/.devcontainer
!/.devcontainer/**
!/backend
!/frontend
!/docs
!/docs/**
!/ops
!/ops/**
!/scripts
!/scripts/**
!/*.code-workspace
!/README.md

# Node modules
backend/node_modules/
frontend/node_modules/

# Build output
frontend/dist/

# Secrets / env
backend/.env
*.env.local

# Database & uploads (runtime data)
backend/prisma/dev.db
backend/prisma/dev.db-journal
backend/uploads/

# Logs
*.log
npm-debug.log*
