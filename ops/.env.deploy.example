# Copy this file to `.env.deploy` on the server and fill in real values.

NODE_ENV=production
PORT=3001

# SQLite persistent DB path inside backend container volume
DATABASE_URL=file:/app/data/dev.db

JWT_SECRET=replace-with-a-strong-random-secret
MAIL_FROM=KingKen Global <no-reply@kingkenglobal.com.ng>
APP_BASE_URL=https://your-domain.example

# SMTP (optional for production mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
