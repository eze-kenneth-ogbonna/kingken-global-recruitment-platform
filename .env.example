# ─────────────────────────────────────────────────────────────────────────────
# KINGKEN GLOBAL RECRUITMENT PLATFORM — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# .env is listed in .gitignore and must stay there.
# ─────────────────────────────────────────────────────────────────────────────

# ─── GOOGLE SHEETS ───────────────────────────────────────────────────────────
# The ID of your main Kingken Global CRM Google Spreadsheet.
# Found in the URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Google Service Account email (for server-side API access in Phase 2)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com

# Google Service Account private key (newlines as \n)
GOOGLE_PRIVATE_KEY=your_private_key_here

# ─── OPENAI / CHATGPT ────────────────────────────────────────────────────────
# OpenAI API key for candidate scoring and matching.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use (gpt-4o recommended for best results)
OPENAI_MODEL=gpt-4o

# ─── WHATSAPP BUSINESS API (WATI / 360dialog) ────────────────────────────────
# WATI API key — found in WATI dashboard → Settings → API
WHATSAPP_API_KEY=your_whatsapp_api_key_here

# WATI API base URL (use your assigned server URL from WATI)
WHATSAPP_API_URL=https://live-mt-server.wati.io/api/v1

# Your WhatsApp Business phone number (with country code, no spaces)
WHATSAPP_BUSINESS_PHONE=+96569048174

# ─── ZAPIER ──────────────────────────────────────────────────────────────────
# Zapier catch webhook URL for manual triggers (optional)
ZAPIER_WEBHOOK_URL=your_zapier_webhook_url_here

# ─── CRM / AIRTABLE (Optional — Phase 2 alternative to Google Sheets) ────────
# Airtable API key (if you switch to Airtable in Phase 2)
AIRTABLE_API_KEY=your_airtable_api_key_if_used

# Airtable Base ID
AIRTABLE_BASE_ID=your_base_id_here

# ─── EMAIL (Gmail SMTP or SendGrid) ──────────────────────────────────────────
# For sending automated emails (confirmations, alerts, reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@kingkenglobal.com.ng

# Use a Gmail App Password (not your main password):
# https://support.google.com/accounts/answer/185833
SMTP_PASS=your_app_password_here

# ─── PLATFORM CONFIGURATION ──────────────────────────────────────────────────
# Environment: development | staging | production
NODE_ENV=development

# Public URL of the Kingken Global website
PLATFORM_URL=https://www.kingkenglobal.com.ng

# Admin email for internal alerts
ADMIN_EMAIL=admin@kingkenglobal.com.ng

# ─── FUTURE PHASE 2 VARIABLES (leave blank for MVP) ──────────────────────────
# PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@host:5432/kingken_db

# Auth0 domain and client ID (for future authentication)
AUTH0_DOMAIN=your_auth0_domain.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret

# JWT secret for API token signing
JWT_SECRET=your_very_long_random_jwt_secret_here

# Stripe payment gateway (for Phase 2 payment integration)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# Flutterwave (alternative payment for African markets)
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key

# SendGrid (for Phase 2 transactional emails)
SENDGRID_API_KEY=your_sendgrid_api_key
